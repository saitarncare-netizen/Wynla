# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# scraper artifacts (~160MB raw HTML cache, regenerable via npm run scrape:pass-data)
/cache
/output

# scratch files Claude Code creates during multi-step work
.tmp-*

# Claude Code local config + scratch handoff docs (not part of the app)
.claude/
MASTER_PROMPT_FOR_NEW_CHAT.md
WYNLA_AUDIT_ROADMAP_*.md

.vercel
.env*.local
